---
import { getCollection } from 'astro:content';
import { skills as groupedSkills } from '../data/skills';

const projects = await getCollection('projects');
const experiences = await getCollection('experiences');
const leaderDots = '. '.repeat(600).trim();
const leaderArrows = '> '.repeat(600).trim();

// Sort experiences by start date descending
const sortedExperiences = experiences.sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf());

// Sort projects by date descending
const sortedProjects = projects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<div class="space-y-14">
  <!-- Projects Section -->
  <section class="space-y-5">
    <header class="group flex items-end gap-3">
      <h2 class="font-serif text-[1.35rem] leading-none text-[#efe4ce]">Projects</h2>
      <span aria-hidden="true" class="leader-switch">
        <span class="leader-dots">
          {leaderDots}
        </span>
        <span class="leader-arrows">
          {leaderArrows}
        </span>
      </span>
      <a href="/projects" class="font-mono text-xs text-[#8f8f95] hover:text-[#d6c6a5] transition-colors">
        see all projects
      </a>
    </header>

    <div class="space-y-7">
      {sortedProjects.slice(0, 3).map((project) => (
        <article class="flex gap-4 items-start group">
          <!-- Thumbnail -->
          <div class="w-14 h-14 flex-shrink-0 bg-[#0f1b2b] rounded-sm overflow-hidden border border-[#243149] group-hover:border-[#3f4f68] transition-colors">
            {project.data.image ? (
              <img src={project.data.image} alt={project.data.title} class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" />
            ) : (
                <div class="w-full h-full flex items-center justify-center bg-[#101a29] text-[#42516a] font-serif text-xl">
                    {project.data.title.charAt(0)}
                </div>
            )}
          </div>

          <!-- Content -->
          <div class="flex-1 space-y-1">
            <div class="flex items-baseline justify-between flex-wrap gap-2">
                <h3 class="font-serif text-[1.45rem] leading-none text-[#e5d8be] group-hover:text-[#f1e7cf] transition-colors">
                <a href={project.data.githubUrl || project.data.liveUrl || '#'}>{project.data.title}</a>
                </h3>
                <div class="font-mono text-xs text-[#7e7f86] uppercase tracking-wide">
                    {project.data.technologies.slice(0, 3).join(', ')}
                </div>
            </div>
            
            <p class="font-sans text-[15px] text-[#898d98] leading-snug max-w-[92%]">
              {project.data.description}
            </p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Experiences Section -->
  <section class="space-y-5">
    <header class="group flex items-end gap-3">
      <h2 class="font-serif text-[1.35rem] leading-none text-[#efe4ce]">Experiences</h2>
      <span aria-hidden="true" class="leader-switch">
        <span class="leader-dots">
          {leaderDots}
        </span>
        <span class="leader-arrows">
          {leaderArrows}
        </span>
      </span>
      <a href="/about" class="font-mono text-xs text-[#8f8f95] hover:text-[#d6c6a5] transition-colors">
        see all experiences
      </a>
    </header>

    <div class="space-y-4">
      {sortedExperiences.slice(0, 3).map((exp) => (
        <div class="grid grid-cols-[42px_1fr] gap-2 group">
          <!-- Year -->
          <div class="font-mono text-[#6d7584] text-xs pt-1">
            {exp.data.startDate.getFullYear()}
          </div>

          <!-- Details -->
          <div class="space-y-1">
            <h3 class="font-serif text-[1.55rem] leading-none text-[#e8dbc1] group-hover:text-[#f1e8d4] transition-colors">
              {exp.data.title}
            </h3>
            <div class="font-mono text-xs tracking-wide text-[#baa67f] uppercase">
              {exp.data.company}
            </div>
            <p class="font-sans text-[15px] text-[#898d98] mt-1 leading-snug max-w-[90%]">
               {exp.data.description.split('\n')[0]}
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Condensed Skills -->
  <section class="space-y-4">
    <header>
      <h2 class="font-serif text-[1.35rem] leading-none text-[#efe4ce]">Skills</h2>
    </header>
    <div class="space-y-2 font-mono text-xs leading-6 text-[#a9a08f]">
      {groupedSkills.map((group) => (
        <p>
          <span class="text-[#c0b28f]">{group.label}:</span>{' '}
          <span>{group.items.join('  •  ')}</span>
        </p>
      ))}
    </div>
  </section>
</div>

<style>
  .leader-switch {
    position: relative;
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
    height: 1em;
    font-family: "EB Garamond", serif;
    font-size: 1.05rem;
    line-height: 1;
    color: rgb(107 101 87 / 0.9);
  }

  .leader-switch > span {
    position: absolute;
    inset: 0;
    white-space: nowrap;
    transition: opacity 180ms ease;
  }

  .leader-arrows {
    opacity: 0;
  }

  .group:hover .leader-dots {
    opacity: 0;
  }

  .group:hover .leader-arrows {
    opacity: 1;
  }
</style>
