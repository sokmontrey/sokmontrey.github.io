---
import MediaCarousel from "./MediaCarousel";

const { media, thumbnail, title } = Astro.props;
const hasMedia = media && media.length > 0;
---

{hasMedia ? (
    <MediaCarousel client:visible media={media} />
) : thumbnail ? (
    <img
        src={thumbnail}
        alt={title}
        class="w-[100%] h-[auto] object-cover rounded-lg shadow-md border border-[var(--lt2-color)]/20"
    />
) : null}
