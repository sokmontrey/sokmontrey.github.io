---
import { getCollection } from 'astro:content';

const writings = await getCollection('things-i-do');
const leaderDots = '. '.repeat(600).trim();
const leaderArrows = '> '.repeat(600).trim();
---

<div class="space-y-7 lg:max-w-[360px]">
    <header class="group flex items-end gap-3">
        <h2 class="font-serif text-[1.35rem] leading-none text-[#efe4ce]">Writings</h2>
        <span aria-hidden="true" class="leader-switch">
            <span class="leader-dots">
                {leaderDots}
            </span>
            <span class="leader-arrows">
                {leaderArrows}
            </span>
        </span>
        <a href="/things-i-do" class="font-mono text-xs text-[#8f8f95] hover:text-[#d6c6a5] transition-colors">
            read more
        </a>
    </header>

    <div class="space-y-8">
    {writings.slice(0, 2).map((item) => (
        <article class="space-y-4 group">
            {item.data.image && (
                <div class="relative overflow-hidden rounded-sm max-w-[320px]">
                   <img 
                        src={item.data.image} 
                        alt={item.data.title} 
                        class="w-full h-auto object-cover opacity-80 transition-opacity duration-500 group-hover:opacity-100"
                    />
                </div>
            )}
             {!item.data.image && (
                <div class="h-28 w-full max-w-[320px] bg-[#0f1b2b] border border-[#243149] flex items-center justify-center">
                    <span class="font-serif text-3xl text-[#3f4f68] italic">?</span>
                </div>
            )}
            
            <div class="space-y-2">
                <h3 class="font-serif text-[1.45rem] leading-tight text-[#e5d8be] group-hover:text-[#f1e7cf] transition-colors">
                    <a href={item.data.link || '#'}>{item.data.title}</a>
                </h3>
                <div class="font-sans text-xs uppercase tracking-wide text-[#8f8f95]">
                    {item.data.category}
                </div>
                <p class="font-sans text-[15px] text-[#898d98] leading-snug">
                    {item.data.description}
                </p>
            </div>
        </article>
    ))}
    </div>
</div>

<style>
  .leader-switch {
    position: relative;
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
    height: 1em;
    font-family: "EB Garamond", serif;
    font-size: 1.05rem;
    line-height: 1;
    color: rgb(107 101 87 / 0.9);
  }

  .leader-switch > span {
    position: absolute;
    inset: 0;
    white-space: nowrap;
    transition: opacity 180ms ease;
  }

  .leader-arrows {
    opacity: 0;
  }

  .group:hover .leader-dots {
    opacity: 0;
  }

  .group:hover .leader-arrows {
    opacity: 1;
  }
</style>
