---
import type { CollectionEntry } from 'astro:content';

interface Props {
	experience: CollectionEntry<'experiences'>;
}

const { experience } = Astro.props;
---

<li>
	<h3>{experience.data.title} at {experience.data.company}</h3>
	<p>
		<strong>Type:</strong> {experience.data.type}
	</p>
	<p>
		<strong>Duration:</strong> {experience.data.startDate.toLocaleDateString()} -{' '}
		{experience.data.endDate
			? experience.data.endDate.toLocaleDateString()
			: 'Present'}
	</p>
	<p>{experience.data.description}</p>
	{experience.data.technologies && experience.data.technologies.length > 0 && (
		<p>
			<strong>Technologies:</strong> {experience.data.technologies.join(', ')}
		</p>
	)}
	{experience.data.achievements && experience.data.achievements.length > 0 && (
		<div>
			<strong>Achievements:</strong>
			<ul>
				{experience.data.achievements.map((achievement) => (
					<li>{achievement}</li>
				))}
			</ul>
		</div>
	)}
</li>

