---
interface Props {
  href: string;
  label: string;
}

const { href, label } = Astro.props;
---

<a
  href={href}
  class="inline-flex items-center text-[#c3b493] hover:text-[#f0e5cf] transition-colors group"
>
  <span
    class="inline-block w-0 overflow-hidden opacity-0 -translate-x-1 group-hover:w-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-200"
    >&gt;</span
  >
  <span>{label}</span>
</a>
