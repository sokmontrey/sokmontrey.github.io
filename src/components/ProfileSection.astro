---
import { Github, Linkedin, Instagram, Mail } from 'lucide-astro';
import links from '../data/links.json';
import WritingSection from './WritingSection.astro';
---

<div class="flex flex-col gap-10">
  <!-- Intro -->
  <div class="space-y-5">
    <h1 class="font-serif text-[2rem] leading-none text-[#efe4ce]">Hi, I&apos;m Sokmontrey</h1>
    <!-- Structured intro table -->
    <table class="table-auto font-sans text-sm text-[#9fa1aa] leading-relaxed border-separate border-spacing-y-1">
      <tbody>
        <tr>
          <td class="pr-1 align-top text-[#9fa1aa] whitespace-nowrap w-[1%]">I</td>
          <td class="pr-2 align-top text-[#e8ddc8] whitespace-nowrap w-[1%]">develop software</td>
          <td class="align-top whitespace-nowrap">with intentional and scalable code</td>
        </tr>
        <tr>
          <td></td>
          <td class="pr-2 align-top text-[#e8ddc8] whitespace-nowrap">make robots</td>
          <td class="align-top whitespace-nowrap">that work, sometimes</td>
        </tr>
        <tr>
          <td></td>
          <td class="pr-2 align-top text-[#e8ddc8] whitespace-nowrap">seek inspiration in things</td>
          <td class="align-top whitespace-nowrap">that bridge art and technology</td>
        </tr>
      </tbody>
    </table>
    
    <div class="flex gap-4 pt-1">
      {links.filter(link => link.isVisible).map((link) => {
        let Icon = Mail;
        if (link.name === 'GitHub') Icon = Github;
        if (link.name === 'LinkedIn') Icon = Linkedin;
        if (link.name === 'Instagram') Icon = Instagram;
        
        return (
          <a href={link.url || '#'} class="text-[#c3b493] hover:text-[#f0e5cf] transition-colors" aria-label={link.name}>
            <Icon class="w-4 h-4" />
          </a>
        );
      })}
    </div>
  </div>

  <!-- Writings (moved here from right sidebar) -->
  <div class="hidden lg:block">
    <WritingSection />
  </div>
</div>
