---
import { Github, Linkedin, Instagram, Mail } from "lucide-astro";
import links from "@/data/links.json";
import ChevronNavLink from "@/components/nav/ChevronNavLink.astro";

const iconClass = "w-5 h-5";
---

<div class="flex flex-col gap-10">
  <div class="space-y-5">
    <h1 class="font-serif text-[2rem] leading-none text-[#EED9B4]">
      Hi, I&apos;m Sokmontrey
    </h1>

    {/* Bio */}
    <div class="text-sm text-[#A59F97] leading-relaxed space-y-3">
      <p>
        From software to robots, to data and AI, to community and art, I <span
          class="text-[#EED9B4]">make things</span
        > and tell its story along the way.
      </p>
      <ChevronNavLink href="/about" label="more about me" class="text-xs" />
    </div>

    {/* Links */}
    <div class="flex gap-7">
      {
        links
          .filter((link) => link.isVisible)
          .map((link) => (
            <a
              href={link.url || "#"}
              class="text-[#A59F97] hover:text-[#f0e5cf] transition-colors"
              aria-label={link.name}
            >
              {link.name === "GitHub" && <Github class={iconClass} />}
              {link.name === "LinkedIn" && <Linkedin class={iconClass} />}
              {link.name === "Instagram" && <Instagram class={iconClass} />}
              {link.name === "Mail" && <Mail class={iconClass} />}
            </a>
          ))
      }
    </div>
  </div>
</div>
