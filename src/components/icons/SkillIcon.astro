---
import * as simpleIcons from "simple-icons";

interface Props {
	name: string;
	size?: number;
	class?: string;
}

const { name, size = 24, class: className = "" } = Astro.props;

// Convert name to simple-icons format (e.g., "react" -> "siReact", "node-dot-js" -> "siNodedotjs")
// Simple Icons uses PascalCase with "si" prefix
const toPascalCase = (str: string): string => {
	return (
		"si" +
		str
			.split(/[-_\s]+/)
			.map(
				(word) =>
					word.charAt(0).toUpperCase() + word.slice(1).toLowerCase(),
			)
			.join("")
	);
};

// Try to find the icon
const iconKey = toPascalCase(name);
let iconData: any = null;

// Try direct key first
if (iconKey in simpleIcons) {
	iconData = (simpleIcons as any)[iconKey];
} else {
	// Try to find by slug
	const iconEntries = Object.entries(simpleIcons);
	const found = iconEntries.find(
		([_, icon]: [string, any]) => icon.slug === name.toLowerCase(),
	);
	if (found) {
		iconData = found[1];
	}
}

let svgString = "";
if (iconData && iconData.svg) {
	// Update SVG viewBox and size
	svgString = iconData.svg
		.replace(/width="[^"]*"/, `width="${size}"`)
		.replace(/height="[^"]*"/, `height="${size}"`);
}
---

{
	iconData && svgString ? (
		<span
			class={className}
			set:html={svgString}
			style={`color: #${iconData.hex};`}
		/>
	) : (
		<span class={className}>{name}</span>
	)
}
