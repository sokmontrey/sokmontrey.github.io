---
import { getAllSkills, getAllProjects, getAllExperiences, getAllThingsIDo } from '../lib/content';
import SkillsSection from '../components/sections/SkillsSection.astro';
import ProjectsSection from '../components/sections/ProjectsSection.astro';
import ExperiencesSection from '../components/sections/ExperiencesSection.astro';
import ThingsIDoSection from '../components/sections/ThingsIDoSection.astro';

const skills = await getAllSkills();
const featuredProjects = await getAllProjects({ featured: true });
const experiences = await getAllExperiences();
const thingsIDo = await getAllThingsIDo();
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Poppins:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet" />
		<title>Portfolio</title>
		<style>
			:root {
				--font-serif: 'EB Garamond', serif;
				--font-sans: 'Poppins', sans-serif;
				--font-mono: 'DM Mono', monospace;
			}
		</style>
	</head>
	<body>
		<main>
			<h1>Portfolio</h1>

			<SkillsSection skills={skills} />
			<ProjectsSection projects={featuredProjects} title="Featured Projects" />
			<ExperiencesSection experiences={experiences} />
			<ThingsIDoSection things={thingsIDo} />
		</main>
	</body>
</html>
