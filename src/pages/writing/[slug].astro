---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ChevronLeft, ExternalLink } from 'lucide-astro';

export async function getStaticPaths() {
  const writings = await getCollection('writing');
  return writings.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const { data } = item;
const { Content } = await render(item);
---

<BaseLayout title={`${data.title} | sokmontrey.me`}>
  <a href="/" class="fixed top-5 left-6 font-sans text-base text-[#A59F97] hover:text-[#EED9B4] transition-colors opacity-50 hover:opacity-100">Sokmontrey</a>
  <main class="mx-auto max-w-3xl px-8 py-16 lg:px-12 lg:py-24">

    <a
      href="/"
      class="mb-8 inline-flex items-center gap-1.5 text-sm text-[#c3b493] hover:text-[#f0e5cf] transition-colors -translate-x-[1.375rem]"
    >
      <ChevronLeft class="h-4 w-4" />
      <span>Back</span>
    </a>

    {data.image && (
      <img src={data.image} alt={data.title} class="mb-8 h-auto opacity-80" />
    )}

    <header class="space-y-2">
      <p class="font-mono text-xs text-[#A59F97] uppercase tracking-wide">{data.category}</p>
      <h1 class="font-serif text-[2.2rem] leading-none text-[#EED9B4]">{data.title}</h1>
    </header>

    {data.link && (
      <a
        href={data.link}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-flex items-center gap-1.5 text-sm text-[#c3b493] hover:text-[#f0e5cf] transition-colors"
      >
        <ExternalLink class="h-4 w-4" />
        <span>View original</span>
      </a>
    )}

    <p class="mt-8 text-base text-[#A59F97] leading-relaxed text-justify">
      {data.description}
    </p>

    <hr class="mt-10 border-[#1e2d42]" />

    <div class="mt-10 prose-content text-[15px] text-[#A59F97] leading-relaxed space-y-4">
      <Content />
    </div>

  </main>
</BaseLayout>

<style is:global>
  .prose-content p { margin-bottom: 1rem; text-align: justify; }
  .prose-content strong { color: #EED9B4; font-weight: 600; }
  .prose-content ul { list-style: disc; padding-left: 1.25rem; }
  .prose-content li { margin-bottom: 0.25rem; }
  .prose-content a { color: #c3b493; text-decoration: underline; text-underline-offset: 3px; }
  .prose-content a:hover { color: #f0e5cf; }
  .prose-content h2 { font-family: "DM Serif Text", serif; font-size: 1.35rem; color: #EED9B4; margin-top: 2rem; margin-bottom: 0.75rem; }
  .prose-content h3 { font-family: "DM Serif Text", serif; font-size: 1.15rem; color: #EED9B4; margin-top: 1.5rem; margin-bottom: 0.5rem; }
  .prose-content code { font-family: "JetBrains Mono", monospace; font-size: 0.8em; color: #baa67f; background: #0f1b2b; padding: 0.1em 0.35em; border-radius: 2px; }
  .prose-content img { display: block; margin: 1.5rem auto; max-width: 75%; height: auto; }
  .prose-content blockquote { border-left: 2px solid #2e3d52; padding-left: 1rem; color: #7a8499; font-style: italic; margin: 1.5rem 0; }
</style>
